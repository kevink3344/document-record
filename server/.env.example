# -------------------------------------------------------
# Required for production (Azure App Service)
# -------------------------------------------------------

# Port — Azure sets this automatically; leave unset locally.
# PORT=3001

# Node environment — must be "production" in Azure.
NODE_ENV=production

# URL(s) of the deployed frontend, comma-separated.
# In Azure this is typically https://<your-app>.azurewebsites.net
# If the client is served by the same app service, this can be omitted
# (the server serves the client files and CORS is not needed).
CORS_ORIGIN=https://<your-app>.azurewebsites.net

# Absolute path for the SQLite database file.
# Azure App Service persistent storage mounts at /home — use a sub-folder.
DB_PATH=/home/data/document-record.db

# Set to "true" to seed demo data on first startup (when DB is empty).
# Safe to set in production — seeding only runs when the DB has no data.
DB_SEED_ON_STARTUP=true
